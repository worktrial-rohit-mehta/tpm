# Required for live TPM-agent runs and any OpenAI-backed authoring synthesis.
OPENAI_API_KEY=sk-...

# Optional when using a compatible proxy or gateway.
# OPENAI_BASE_URL=https://your-compatible-endpoint.example/v1

# The standardized TPM harness keeps the prompt pack and action schema fixed.
# Change only the model when you want to compare model quality under the same harness.
TPM_AGENT_MODEL=<your-openai-model>

# Optional separate default for OpenAI-backed authoring commands.
# If unset, authoring falls back to TPM_AGENT_MODEL.
# TPM_AUTHORING_MODEL=<your-top-authoring-model>

# Default output root for local artifacts if you want to standardize where runs land.
TPM_ARTIFACT_DIR=.artifacts
